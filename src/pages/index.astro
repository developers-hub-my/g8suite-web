---
import BaseLayout from '~/layouts/BaseLayout.astro';
import Nav from '~/components/Nav.astro';
import Hero from '~/components/Hero.astro';
import ProblemSection from '~/components/ProblemSection.astro';
import PlatformOverview from '~/components/PlatformOverview.astro';
import BuiltFor from '~/components/BuiltFor.astro';
import Differentiators from '~/components/Differentiators.astro';
import Stage1Products from '~/components/Stage1Products.astro';
import Stage2Products from '~/components/Stage2Products.astro';
import ArchitecturalFoundations from '~/components/ArchitecturalFoundations.astro';
import Roadmap from '~/components/Roadmap.astro';
import CTA from '~/components/CTA.astro';
import Footer from '~/components/Footer.astro';
---

<BaseLayout>
  <Nav />
  <main id="main">
    <Hero />
    <ProblemSection />
    <PlatformOverview />
    <BuiltFor />
    <Differentiators />
    <Stage1Products />
    <Stage2Products />
    <ArchitecturalFoundations />
    <Roadmap />
    <CTA />
  </main>
  <Footer />
</BaseLayout>
