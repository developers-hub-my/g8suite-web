---
import SectionHeader from '~/components/ui/SectionHeader.astro';

const phases = [
  {
    label: 'Foundation',
    when: 'Today',
    body: 'G8ID live in production. g8stack, g8connect, g8scope, and g8deck in active development with reference customers.',
    state: 'current',
  },
  {
    label: 'Expansion',
    when: '18 months',
    body: 'Stage 1 portfolio complete. SOC 2 Type I attestation. Anchored partner network operating in Singapore and the GCC.',
    state: 'next',
  },
  {
    label: 'Scale',
    when: '36 months',
    body: 'Stage 2 begins — first business operations products on the shared spine. Public g8suite brand launch in target markets.',
    state: 'future',
  },
  {
    label: 'Federation',
    when: '60+ months',
    body: 'Full Stage 2 portfolio in market. Federated partner network across ASEAN, MENA, and EU sovereignty-aligned regions.',
    state: 'future',
  },
];
---

<section id="roadmap" class="section bg-surface">
  <div class="container-page">
    <SectionHeader
      eyebrow="Roadmap"
      title="Where we go from here"
      subtitle="Foundations before features. Stage 1 before Stage 2. Sovereignty before scale."
    />

    <ol class="mt-14 grid gap-6 lg:grid-cols-4 lg:gap-0">
      {phases.map((phase, i) => {
        const isCurrent = phase.state === 'current';
        return (
          <li class="relative lg:px-4">
            <div class="hidden lg:block absolute left-0 top-6 h-px w-full bg-slate-200" aria-hidden="true"></div>
            <div class="relative">
              <span class={`relative z-10 inline-flex h-3 w-3 items-center justify-center rounded-full ${isCurrent ? 'bg-accent-green' : 'bg-navy-900'}`}>
                {isCurrent && (
                  <span class="absolute inline-flex h-full w-full animate-ping rounded-full bg-accent-green opacity-50" aria-hidden="true"></span>
                )}
              </span>
              <p class="mt-5 text-xs font-semibold uppercase tracking-[0.18em] text-sky-400">
                Phase {i + 1} · {phase.when}
              </p>
              <h3 class="mt-2 text-xl font-semibold text-navy-900">{phase.label}</h3>
              <p class="mt-3 text-sm leading-relaxed text-ink-600">{phase.body}</p>
            </div>
          </li>
        );
      })}
    </ol>
  </div>
</section>
