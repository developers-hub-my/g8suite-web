---
import { Icon } from 'astro-icon/components';
import SectionHeader from '~/components/ui/SectionHeader.astro';

const segments = [
  {
    icon: 'lucide:landmark',
    title: 'Government',
    body: 'Federal and state agencies running citizen services and regulated programmes under sovereignty mandates that cloud-only vendors cannot satisfy.',
  },
  {
    icon: 'lucide:building-2',
    title: 'Banks & Finance',
    body: 'Tier-1 and tier-2 banks, takaful and insurance, and capital markets firms operating under central bank and regulator scrutiny.',
  },
  {
    icon: 'lucide:stethoscope',
    title: 'Healthcare',
    body: 'Hospitals, group practices, and national health systems where data residency, identity, and audit are statutory obligations.',
  },
  {
    icon: 'lucide:shield',
    title: 'Defence & Security',
    body: 'Defence ministries, security services, and critical national infrastructure operators that require air-gapped deployments and cleared supply chains.',
  },
  {
    icon: 'lucide:building',
    title: 'Regulated Mid-Market',
    body: 'Energy, utilities, telecommunications, and regulated industrials — quietly running a country, quietly carrying the same compliance burden.',
  },
];
---

<section id="built-for" class="section bg-surface">
  <div class="container-page">
    <SectionHeader
      eyebrow="Built for"
      title="Organisations where compliance isn't optional."
      subtitle="g8suite is built for the operating contexts where identity sprawl is an active liability, not a tolerable inconvenience."
    />

    <div class="mt-14 grid gap-px overflow-hidden rounded-2xl border border-slate-200 bg-slate-200 sm:grid-cols-2 lg:grid-cols-5">
      {segments.map((seg) => (
        <article class="group flex h-full flex-col bg-surface p-7 transition-colors hover:bg-surface-soft">
          <span class="inline-flex h-10 w-10 items-center justify-center rounded-lg bg-navy-900/5 text-navy-900 transition-colors group-hover:bg-navy-900 group-hover:text-white">
            <Icon name={seg.icon} class="h-5 w-5" aria-hidden="true" />
          </span>
          <h3 class="mt-5 text-base font-semibold text-navy-900">{seg.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-ink-600">{seg.body}</p>
        </article>
      ))}
    </div>

    <div class="mt-10 flex flex-col items-start justify-between gap-3 rounded-2xl border border-slate-200 bg-surface-soft p-6 md:flex-row md:items-center">
      <p class="text-sm text-ink-600">
        ASEAN · MENA · regulated mid-market — the markets where data sovereignty is mandated, not aspirational.
      </p>
      <a href="#contact" class="inline-flex items-center gap-1.5 text-sm font-medium text-navy-900 hover:text-navy-700">
        Talk about your context
        <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
          <path d="M2 7h10M8 3l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
        </svg>
      </a>
    </div>
  </div>
</section>
