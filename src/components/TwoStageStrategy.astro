---
import SectionHeader from '~/components/ui/SectionHeader.astro';

const stage1 = [
  'Identity governance and access certification',
  'API gateway and lifecycle management',
  'No-code data integration pipelines',
  'Provisioning and platform operations',
  'Posture management and vulnerability scanning',
  'Metrics, logs, and distributed tracing',
  'Workflow orchestration and automation',
  'Unified audit trail and evidence collection',
];

const stage2 = [
  'Workforce records and lifecycle (HR)',
  'Document and record management',
  'Procurement and vendor management',
  'Customer relationship management',
  'Service desk and ticketing',
  'Financial operations and ledgers',
];
---

<section id="strategy" class="section bg-surface">
  <div class="container-page">
    <SectionHeader
      eyebrow="Two-stage strategy"
      title="The two-stage platform"
      subtitle="A deliberate sequencing strategy: infrastructure before applications, foundations before features."
    />

    <div class="mt-14 grid gap-6 lg:grid-cols-2">
      <article class="rounded-lg border border-navy-900/15 bg-surface p-8">
        <div class="flex items-center justify-between">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-400">
            Stage 1 — Years 1–3
          </p>
          <span class="pill-live">Current focus</span>
        </div>
        <h3 class="mt-3 text-2xl font-semibold text-navy-900">IT Operations</h3>
        <p class="mt-2 text-sm text-ink-600">The infrastructure spine that everything else stands on.</p>
        <ul class="mt-6 space-y-3">
          {stage1.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="mt-1 h-4 w-4 flex-shrink-0 text-navy-900" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M3 8l3.5 3.5L13 4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="text-sm text-ink-900">{item}</span>
            </li>
          ))}
        </ul>
      </article>

      <article class="rounded-lg border border-slate-200 bg-surface-soft p-8">
        <div class="flex items-center justify-between">
          <p class="text-xs font-semibold uppercase tracking-[0.18em] text-ink-400">
            Stage 2 — Years 3–7
          </p>
          <span class="pill-planned">Future</span>
        </div>
        <h3 class="mt-3 text-2xl font-semibold text-ink-900/80">Business Operations</h3>
        <p class="mt-2 text-sm text-ink-600">The applications that ride the spine, once it has earned trust.</p>
        <ul class="mt-6 space-y-3">
          {stage2.map((item) => (
            <li class="flex items-start gap-3">
              <svg class="mt-1 h-4 w-4 flex-shrink-0 text-ink-400" viewBox="0 0 16 16" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
                <path d="M3 8l3.5 3.5L13 4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
              <span class="text-sm text-ink-600">{item}</span>
            </li>
          ))}
        </ul>
      </article>
    </div>

    <div class="mt-10 rounded-md border-l-4 border-sky-400 bg-sky-100/40 p-6">
      <p class="text-base leading-relaxed text-navy-900">
        Infrastructure products feed business apps. Regulated buyers validate infrastructure first. The two stages share a single architectural spine.
      </p>
    </div>
  </div>
</section>
