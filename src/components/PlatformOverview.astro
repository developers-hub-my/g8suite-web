---
import SectionHeader from '~/components/ui/SectionHeader.astro';

const pillars = [
  {
    title: 'One Platform',
    body: 'A single, coherent system replacing dozens of disconnected tools — designed and built as one suite, not assembled from acquisitions.',
  },
  {
    title: 'One Vendor',
    body: 'One contract. One support relationship. One accountability chain. No more 2am triage across half a dozen vendor portals.',
  },
  {
    title: 'One Source of Truth',
    body: 'Deployed inside your perimeter. Answerable to you — not a cloud provider. Identity, audit, and operations live where your data lives.',
  },
];

const layers = [
  {
    tier: 'Apex',
    label: 'Business Operations',
    members: 'g8hr · g8docs · g8procure · g8crm · g8desk · g8finance',
  },
  {
    tier: 'Trust plane',
    label: 'Audit · Secrets · Infrastructure',
    members: 'g8audit · g8vault · g8deck',
  },
  {
    tier: 'Operations plane',
    label: 'Workflow · Observability · Compliance',
    members: 'g8flow · g8scope · g8shield',
  },
  {
    tier: 'Foundation',
    label: 'Identity · APIs · Data',
    members: 'G8ID · g8stack · g8connect · g8key',
  },
];
---

<section id="platform" class="section bg-surface-soft">
  <div class="container-page">
    <SectionHeader
      eyebrow="The platform"
      title="g8suite replaces the sprawl with one platform."
      subtitle="An operating system for organisations that refuse to compromise on sovereignty — built as one suite from the ground up."
    />

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {pillars.map((pillar) => (
        <div class="rounded-xl border border-sky-100 bg-surface p-7">
          <h3 class="text-xl font-semibold text-navy-900">{pillar.title}</h3>
          <p class="mt-3 text-base leading-relaxed text-ink-600">{pillar.body}</p>
        </div>
      ))}
    </div>

    <div class="mt-20">
      <p class="text-center text-xs font-semibold uppercase tracking-[0.18em] text-sky-400">
        The layered architecture
      </p>
      <h3 class="mx-auto mt-3 max-w-3xl text-center text-2xl font-semibold leading-tight text-navy-900 sm:text-3xl">
        Foundation feeds operations. Operations feed trust. Trust enables business.
      </h3>

      <div class="mt-12 grid items-center gap-12 lg:grid-cols-12 lg:gap-16">
        <div class="order-2 lg:order-1 lg:col-span-5">
          <svg
            viewBox="0 0 420 360"
            class="mx-auto h-auto w-full max-w-md"
            role="img"
            aria-labelledby="stack-title"
          >
            <title id="stack-title">
              Isometric four-layer architecture: foundation, operations plane, trust plane, business apex.
            </title>

            <!-- Layer 4 — Foundation (widest, base) -->
            <g>
              <polygon points="40,300 380,300 340,330 80,330" fill="#FFFFFF" stroke="#0A1F44" stroke-width="1.5" />
              <polygon points="40,300 80,330 80,310 40,280" fill="#F1F5F9" stroke="#0A1F44" stroke-width="1.5" />
              <polygon points="380,300 340,330 340,310 380,280" fill="#E2E8F0" stroke="#0A1F44" stroke-width="1.5" />
              <text x="210" y="320" text-anchor="middle" font-size="11" font-weight="600" fill="#0A1F44" font-family="Inter, system-ui, sans-serif">Foundation</text>
            </g>

            <!-- Layer 3 — Operations plane -->
            <g>
              <polygon points="70,230 350,230 310,260 110,260" fill="#DCE9F5" stroke="#0A1F44" stroke-width="1.5" />
              <polygon points="70,230 110,260 110,240 70,210" fill="#7BB3E8" fill-opacity="0.4" stroke="#0A1F44" stroke-width="1.5" />
              <polygon points="350,230 310,260 310,240 350,210" fill="#7BB3E8" fill-opacity="0.55" stroke="#0A1F44" stroke-width="1.5" />
              <text x="210" y="250" text-anchor="middle" font-size="11" font-weight="600" fill="#0A1F44" font-family="Inter, system-ui, sans-serif">Operations plane</text>
            </g>

            <!-- Layer 2 — Trust plane -->
            <g>
              <polygon points="100,160 320,160 280,190 140,190" fill="#1E3A6F" stroke="#0A1F44" stroke-width="1.5" />
              <polygon points="100,160 140,190 140,170 100,140" fill="#0A1F44" stroke="#0A1F44" stroke-width="1.5" />
              <polygon points="320,160 280,190 280,170 320,140" fill="#3B5998" stroke="#0A1F44" stroke-width="1.5" />
              <text x="210" y="180" text-anchor="middle" font-size="11" font-weight="600" fill="#FFFFFF" font-family="Inter, system-ui, sans-serif">Trust plane</text>
            </g>

            <!-- Layer 1 — Apex (smallest, top) -->
            <g>
              <polygon points="140,90 280,90 240,120 180,120" fill="#0A1F44" stroke="#0A1F44" stroke-width="1.5" />
              <polygon points="140,90 180,120 180,100 140,70" fill="#0A1F44" stroke="#0A1F44" stroke-width="1.5" />
              <polygon points="280,90 240,120 240,100 280,70" fill="#1E3A6F" stroke="#0A1F44" stroke-width="1.5" />
              <text x="210" y="110" text-anchor="middle" font-size="11" font-weight="600" fill="#FFFFFF" font-family="Inter, system-ui, sans-serif">Apex</text>
            </g>

            <!-- Sovereignty crown -->
            <g>
              <path d="M195 56 L195 72 L225 72 L225 56 L218 62 L210 50 L202 62 Z" fill="#7BB3E8" stroke="#0A1F44" stroke-width="1.25" stroke-linejoin="round" />
              <circle cx="210" cy="48" r="2.5" fill="#0A1F44" />
            </g>

            <!-- Connection arrows -->
            <g stroke="#7BB3E8" stroke-width="1.25" fill="none" opacity="0.7">
              <path d="M210 200 L210 215" stroke-linecap="round" />
              <path d="M210 270 L210 285" stroke-linecap="round" />
              <path d="M206 215 L210 220 L214 215" stroke-linecap="round" stroke-linejoin="round" />
              <path d="M206 285 L210 290 L214 285" stroke-linecap="round" stroke-linejoin="round" />
            </g>
          </svg>
        </div>

        <div class="order-1 lg:order-2 lg:col-span-7">
          <ol class="space-y-3">
            {layers.map((layer, i) => (
              <li class="flex items-start gap-4 rounded-lg border border-slate-200 bg-surface p-5 transition-colors hover:border-navy-900/30">
                <span class="mt-0.5 inline-flex h-7 w-7 flex-shrink-0 items-center justify-center rounded-full bg-navy-900 font-mono text-xs font-semibold text-white">
                  {String(i + 1).padStart(2, '0')}
                </span>
                <div class="min-w-0 flex-1">
                  <div class="flex flex-wrap items-baseline justify-between gap-2">
                    <p class="text-base font-semibold text-navy-900">{layer.label}</p>
                    <span class="text-xs font-medium uppercase tracking-wider text-ink-400">{layer.tier}</span>
                  </div>
                  <p class="mt-1 font-mono text-xs leading-relaxed text-ink-600">{layer.members}</p>
                </div>
              </li>
            ))}
          </ol>
        </div>
      </div>
    </div>
  </div>
</section>
