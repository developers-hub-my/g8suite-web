---
import type { ProductStatus } from '~/content/products';
import { statusLabel } from '~/content/products';

export interface Props {
  name: string;
  description: string;
  status: ProductStatus;
  note?: string;
}

const { name, description, status, note } = Astro.props;

const pillClass =
  status === 'live' ? 'pill-live' : status === 'in-development' ? 'pill-dev' : 'pill-planned';
---

<article class="group flex h-full flex-col rounded-lg border border-slate-200 bg-surface p-6 transition-colors hover:border-navy-900/40">
  <div class="flex items-center justify-between gap-4">
    <h3 class="text-lg font-semibold text-navy-900">{name}</h3>
    <span class={pillClass}>{statusLabel[status]}</span>
  </div>
  <p class="mt-3 text-sm leading-relaxed text-ink-600">{description}</p>
  {note && (
    <p class="mt-4 border-t border-slate-100 pt-3 text-xs italic text-ink-400">{note}</p>
  )}
</article>
