---
export interface Props {
  index: number;
  title: string;
  description: string;
}

const { index, title, description } = Astro.props;
const padded = String(index).padStart(2, '0');
---

<article class="flex h-full flex-col rounded-lg border border-slate-200 bg-surface-soft p-6">
  <div class="flex items-center gap-3">
    <span class="font-mono text-xs font-medium tracking-wider text-sky-400">{padded}</span>
    <span class="h-px flex-1 bg-slate-200"></span>
  </div>
  <h3 class="mt-4 text-lg font-semibold text-navy-900">{title}</h3>
  <p class="mt-2 text-sm leading-relaxed text-ink-600">{description}</p>
</article>
