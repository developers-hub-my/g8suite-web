---
import SectionHeader from '~/components/ui/SectionHeader.astro';
import { stage1Products, statusLabel } from '~/content/products';

const liveCount = stage1Products.filter((p) => p.status === 'live').length;
const devCount = stage1Products.filter((p) => p.status === 'in-development').length;
const plannedCount = stage1Products.filter((p) => p.status === 'planned').length;

const pillClass = (status: 'live' | 'in-development' | 'planned') =>
  status === 'live' ? 'pill-live' : status === 'in-development' ? 'pill-dev' : 'pill-planned';
---

<section id="products" class="section bg-surface-soft">
  <div class="container-page">
    <div class="grid items-end gap-8 lg:grid-cols-12">
      <div class="lg:col-span-8">
        <SectionHeader
          eyebrow="Stage 1 — IT Operations"
          title="Ten products. One integrated platform."
          subtitle="The IT operations spine that everything else stands on. Adopt the products you need today, add the rest as your operating model matures."
        />
      </div>
      <div class="lg:col-span-4">
        <dl class="grid grid-cols-3 gap-4 rounded-xl border border-slate-200 bg-surface p-5 text-center">
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wider text-ink-400">Live</dt>
            <dd class="mt-1 font-mono text-2xl font-bold text-accent-green">{liveCount}</dd>
          </div>
          <div class="border-x border-slate-200">
            <dt class="text-xs font-semibold uppercase tracking-wider text-ink-400">In dev</dt>
            <dd class="mt-1 font-mono text-2xl font-bold text-navy-700">{devCount}</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wider text-ink-400">Planned</dt>
            <dd class="mt-1 font-mono text-2xl font-bold text-ink-400">{plannedCount}</dd>
          </div>
        </dl>
      </div>
    </div>

    <div class="mt-12 grid gap-4 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4">
      {stage1Products.map((p) => {
        const isLive = p.status === 'live';
        return (
          <article
            class={`group relative flex h-full flex-col rounded-xl border p-6 transition-all hover:-translate-y-0.5 hover:shadow-elevated ${
              isLive
                ? 'border-accent-green/30 bg-surface ring-1 ring-accent-green/10'
                : 'border-slate-200 bg-surface'
            }`}
          >
            <div class="flex items-start justify-between gap-3">
              <div class="min-w-0">
                <p class="text-xs font-semibold uppercase tracking-wider text-ink-400">
                  {p.category}
                </p>
                <h3 class="mt-1.5 font-mono text-xl font-bold text-navy-900">{p.name}</h3>
              </div>
              <span class={pillClass(p.status)}>{statusLabel[p.status]}</span>
            </div>
            <p class="mt-4 flex-1 text-sm leading-relaxed text-ink-600">{p.focus}</p>
            <div class="mt-5 flex items-center gap-2 border-t border-slate-100 pt-4 text-xs font-medium text-ink-400">
              <span class={`h-1.5 w-1.5 rounded-full ${isLive ? 'bg-accent-green' : p.status === 'in-development' ? 'bg-sky-400' : 'bg-slate-300'}`}></span>
              <span>{isLive ? 'In production' : p.status === 'in-development' ? 'Active development' : 'Roadmap'}</span>
            </div>
          </article>
        );
      })}
    </div>
  </div>
</section>
