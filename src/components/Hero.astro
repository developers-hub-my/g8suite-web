---
const spine = [
  { label: 'Identity', sub: 'G8ID' },
  { label: 'Audit', sub: 'g8audit' },
  { label: 'Workflow', sub: 'g8flow' },
];

const orbit = [
  { name: 'g8stack', x: 70, y: 18 },
  { name: 'g8connect', x: 78, y: 50 },
  { name: 'g8scope', x: 70, y: 82 },
  { name: 'g8shield', x: 22, y: 18 },
  { name: 'g8deck', x: 14, y: 50 },
  { name: 'g8vault', x: 22, y: 82 },
];
---

<section id="top" class="relative overflow-hidden pt-32 pb-20 lg:pt-40 lg:pb-28">
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    aria-hidden="true"
    style="background: radial-gradient(900px 500px at 80% 0%, rgba(123,179,232,0.10), transparent 60%), radial-gradient(700px 400px at 0% 20%, rgba(10,31,68,0.04), transparent 60%);"
  ></div>

  <div class="container-page">
    <div class="grid gap-16 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-7">
        <p class="mb-5 inline-flex items-center gap-2 rounded-full border border-sky-400/30 bg-sky-100/40 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-navy-700">
          <span class="h-1.5 w-1.5 rounded-full bg-accent-green"></span>
          Sovereign · Integrated · Yours
        </p>
        <h1 class="text-4xl font-bold leading-[1.05] tracking-tight text-navy-900 sm:text-5xl lg:text-6xl xl:text-7xl">
          One platform.<br />
          Your whole operation.<br />
          <span class="text-sky-400">Your rules.</span>
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-600 lg:text-xl">
          g8suite is the sovereign enterprise operations platform for organisations where compliance isn't optional and identity sprawl is an active liability. One platform, deployed inside your perimeter — answerable to you, not a cloud provider.
        </p>
        <div class="mt-10 flex flex-col gap-3 sm:flex-row">
          <a href="#contact" class="btn-primary">Request a Demo</a>
          <a href="#platform" class="btn-ghost">Explore the Platform</a>
        </div>

        <dl class="mt-12 grid max-w-xl grid-cols-3 gap-6 border-t border-slate-200 pt-8">
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wider text-ink-400">Deployment</dt>
            <dd class="mt-1 text-sm font-semibold text-navy-900">On-prem or air-gapped</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wider text-ink-400">Spine</dt>
            <dd class="mt-1 text-sm font-semibold text-navy-900">Identity · Audit · Workflow</dd>
          </div>
          <div>
            <dt class="text-xs font-semibold uppercase tracking-wider text-ink-400">Coverage</dt>
            <dd class="mt-1 text-sm font-semibold text-navy-900">IT &amp; business ops</dd>
          </div>
        </dl>
      </div>

      <div class="lg:col-span-5">
        <figure class="relative mx-auto max-w-md lg:max-w-none">
          <svg
            viewBox="0 0 480 520"
            class="h-auto w-full select-none"
            role="img"
            aria-labelledby="hero-diagram-title"
          >
            <title id="hero-diagram-title">
              The g8suite operations spine — identity, audit, and workflow inside a sovereign perimeter, with product modules orbiting around it.
            </title>

            <!-- Sovereign perimeter -->
            <rect
              x="20"
              y="20"
              width="440"
              height="480"
              rx="12"
              fill="none"
              stroke="#7BB3E8"
              stroke-width="1.5"
              stroke-dasharray="6 6"
              opacity="0.7"
            />
            <!-- Perimeter corner ticks -->
            <g stroke="#0A1F44" stroke-width="2" fill="none">
              <path d="M20 40 L20 20 L40 20" />
              <path d="M460 40 L460 20 L440 20" />
              <path d="M20 480 L20 500 L40 500" />
              <path d="M460 480 L460 500 L440 500" />
            </g>
            <text
              x="240"
              y="14"
              text-anchor="middle"
              font-size="9"
              font-family="ui-monospace, monospace"
              fill="#475569"
              letter-spacing="0.18em"
            >YOUR PERIMETER</text>

            <!-- Subtle grid -->
            <g stroke="#E2E8F0" stroke-width="0.5" opacity="0.6">
              <line x1="20" y1="180" x2="460" y2="180" />
              <line x1="20" y1="340" x2="460" y2="340" />
              <line x1="160" y1="20" x2="160" y2="500" />
              <line x1="320" y1="20" x2="320" y2="500" />
            </g>

            <!-- Connector lines from spine to orbit -->
            <g stroke="#7BB3E8" stroke-width="1" opacity="0.7" fill="none">
              {orbit.map((node) => {
                const cx = (node.x / 100) * 440 + 20;
                const cy = (node.y / 100) * 480 + 20;
                return <line x1="240" y1="260" x2={cx} y2={cy} stroke-dasharray="2 4" />;
              })}
            </g>

            <!-- Central spine plate -->
            <g>
              <rect x="180" y="120" width="120" height="280" rx="8" fill="#0A1F44" />
              <rect x="184" y="124" width="112" height="272" rx="6" fill="none" stroke="#7BB3E8" stroke-width="0.5" opacity="0.4" />
              <text
                x="240"
                y="108"
                text-anchor="middle"
                font-size="9"
                font-family="ui-monospace, monospace"
                fill="#475569"
                letter-spacing="0.2em"
              >THE SPINE</text>
              {spine.map((s, i) => {
                const y = 160 + i * 80;
                return (
                  <g>
                    <rect
                      x="196"
                      y={y - 24}
                      width="88"
                      height="48"
                      rx="4"
                      fill="#1E3A6F"
                      stroke="#7BB3E8"
                      stroke-width="0.5"
                      opacity="0.95"
                    />
                    <text
                      x="240"
                      y={y - 5}
                      text-anchor="middle"
                      font-size="13"
                      font-weight="600"
                      fill="#FFFFFF"
                      font-family="Inter, system-ui, sans-serif"
                    >
                      {s.label}
                    </text>
                    <text
                      x="240"
                      y={y + 12}
                      text-anchor="middle"
                      font-size="10"
                      fill="#7BB3E8"
                      font-family="ui-monospace, monospace"
                    >
                      {s.sub}
                    </text>
                  </g>
                );
              })}
            </g>

            <!-- Orbit product chips -->
            <g font-family="ui-monospace, monospace" font-size="11">
              {orbit.map((node) => {
                const cx = (node.x / 100) * 440 + 20;
                const cy = (node.y / 100) * 480 + 20;
                return (
                  <g>
                    <rect
                      x={cx - 38}
                      y={cy - 14}
                      width="76"
                      height="28"
                      rx="14"
                      fill="#FFFFFF"
                      stroke="#0A1F44"
                      stroke-width="1.25"
                    />
                    <text
                      x={cx}
                      y={cy + 4}
                      text-anchor="middle"
                      fill="#0A1F44"
                      font-weight="600"
                    >
                      {node.name}
                    </text>
                  </g>
                );
              })}
            </g>
          </svg>
        </figure>
      </div>
    </div>

    <div class="mt-20 flex items-center gap-6 lg:mt-28">
      <span class="h-px flex-1 bg-slate-200"></span>
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-ink-400">
        Trusted infrastructure for regulated organisations
      </p>
      <span class="h-px flex-1 bg-slate-200"></span>
    </div>
  </div>
</section>
