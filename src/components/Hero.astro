---
---

<section id="top" class="relative overflow-hidden pt-32 pb-20 lg:pt-40 lg:pb-28">
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    aria-hidden="true"
    style="background: radial-gradient(900px 500px at 80% 0%, rgba(123,179,232,0.10), transparent 60%), radial-gradient(700px 400px at 0% 20%, rgba(10,31,68,0.04), transparent 60%);"
  ></div>

  <div class="container-page">
    <div class="grid gap-16 lg:grid-cols-12 lg:items-center">
      <div class="lg:col-span-7">
        <p class="mb-5 text-sm font-medium uppercase tracking-[0.18em] text-sky-400">
          The sovereign enterprise operations platform
        </p>
        <h1 class="text-4xl font-semibold leading-[1.05] tracking-tight text-navy-900 sm:text-5xl lg:text-6xl xl:text-7xl">
          One platform.<br />
          Your whole operation.<br />
          Your rules.
        </h1>
        <p class="mt-6 max-w-2xl text-lg leading-relaxed text-ink-600 lg:text-xl">
          g8suite is built for organisations where compliance isn't optional and identity sprawl is an active liability. One platform, deployed inside your perimeter — answerable to you, not a cloud provider.
        </p>
        <div class="mt-10 flex flex-col gap-3 sm:flex-row">
          <a href="#contact" class="btn-primary">Request a Demo</a>
          <a href="#platform" class="btn-ghost">Explore the Platform</a>
        </div>
      </div>

      <div class="lg:col-span-5">
        <div class="relative mx-auto aspect-square max-w-md">
          <svg
            viewBox="0 0 400 400"
            xmlns="http://www.w3.org/2000/svg"
            class="h-full w-full"
            aria-hidden="true"
          >
            <defs>
              <pattern id="grid" width="20" height="20" patternUnits="userSpaceOnUse">
                <path d="M 20 0 L 0 0 0 20" fill="none" stroke="#DCE9F5" stroke-width="0.5" />
              </pattern>
            </defs>
            <rect width="400" height="400" fill="url(#grid)" opacity="0.5" />

            <g stroke="#0A1F44" stroke-width="1.5" fill="none" stroke-linejoin="round">
              <polygon points="200,80 320,140 320,260 200,320 80,260 80,140" />
              <polygon points="200,80 320,140 200,200 80,140" />
              <polygon points="80,140 200,200 200,320 80,260" />
              <polygon points="320,140 320,260 200,320 200,200" />

              <line x1="200" y1="80" x2="200" y2="200" />
              <line x1="80" y1="140" x2="200" y2="200" />
              <line x1="320" y1="140" x2="200" y2="200" />
              <line x1="200" y1="200" x2="200" y2="320" />
            </g>

            <g stroke="#7BB3E8" stroke-width="1" fill="none" opacity="0.7">
              <polygon points="200,120 280,160 280,240 200,280 120,240 120,160" />
              <line x1="200" y1="120" x2="200" y2="280" stroke-dasharray="3 3" />
              <line x1="120" y1="160" x2="280" y2="240" stroke-dasharray="3 3" />
              <line x1="280" y1="160" x2="120" y2="240" stroke-dasharray="3 3" />
            </g>

            <g fill="#0A1F44">
              <circle cx="200" cy="80" r="3" />
              <circle cx="320" cy="140" r="3" />
              <circle cx="320" cy="260" r="3" />
              <circle cx="200" cy="320" r="3" />
              <circle cx="80" cy="260" r="3" />
              <circle cx="80" cy="140" r="3" />
              <circle cx="200" cy="200" r="3" />
            </g>

            <g fill="#7BB3E8">
              <circle cx="200" cy="120" r="2" />
              <circle cx="280" cy="160" r="2" />
              <circle cx="280" cy="240" r="2" />
              <circle cx="200" cy="280" r="2" />
              <circle cx="120" cy="240" r="2" />
              <circle cx="120" cy="160" r="2" />
            </g>
          </svg>
        </div>
      </div>
    </div>

    <div class="mt-20 flex items-center gap-6 lg:mt-28">
      <span class="h-px flex-1 bg-slate-200"></span>
      <p class="text-xs font-medium uppercase tracking-[0.18em] text-ink-400">
        Trusted infrastructure for regulated organisations
      </p>
      <span class="h-px flex-1 bg-slate-200"></span>
    </div>
  </div>
</section>
