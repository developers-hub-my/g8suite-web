---
import SectionHeader from '~/components/ui/SectionHeader.astro';
import { stage2Waves, statusLabel } from '~/content/products';

const pillClass = (status: 'live' | 'in-development' | 'planned') =>
  status === 'live' ? 'pill-live' : status === 'in-development' ? 'pill-dev' : 'pill-planned';
---

<section id="stage-2" class="section bg-surface">
  <div class="container-page">
    <SectionHeader
      eyebrow="Stage 2 — Business Operations"
      title="Six products across three waves."
      subtitle="Business operations products that ride the mature Stage 1 spine — sequenced deliberately, not all at once."
    />

    <!-- Timeline -->
    <div class="mt-14 hidden lg:block">
      <div class="relative">
        <div class="absolute left-0 right-0 top-12 h-px bg-slate-200" aria-hidden="true"></div>
        <ol class="grid grid-cols-3 gap-6">
          {stage2Waves.map((wave, i) => (
            <li class="relative">
              <div class="flex items-center gap-3">
                <span class="relative z-10 inline-flex h-8 w-8 items-center justify-center rounded-full border-2 border-navy-900 bg-surface font-mono text-xs font-bold text-navy-900">
                  {i + 1}
                </span>
                <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-400">
                  {wave.timeframe}
                </p>
              </div>
              <div class="mt-5">
                <h3 class="text-2xl font-semibold text-navy-900">{wave.label}</h3>
                <p class="mt-1 text-sm text-ink-600">
                  {wave.products.length} {wave.products.length === 1 ? 'product' : 'products'}
                </p>
              </div>
              <div class="mt-6 space-y-3">
                {wave.products.map((product) => (
                  <article class="rounded-xl border border-slate-200 bg-surface p-5 transition-all hover:-translate-y-0.5 hover:border-navy-900/30 hover:shadow-elevated">
                    <div class="flex items-center justify-between gap-3">
                      <h4 class="font-mono text-lg font-bold text-navy-900">{product.name}</h4>
                      <span class={pillClass(product.status)}>{statusLabel[product.status]}</span>
                    </div>
                    <p class="mt-3 text-sm leading-relaxed text-ink-600">{product.description}</p>
                    {product.note && (
                      <p class="mt-3 border-t border-slate-100 pt-2.5 text-xs italic text-ink-400">
                        {product.note}
                      </p>
                    )}
                  </article>
                ))}
              </div>
            </li>
          ))}
        </ol>
      </div>
    </div>

    <!-- Mobile / tablet stack -->
    <ol class="mt-14 space-y-10 lg:hidden">
      {stage2Waves.map((wave, i) => (
        <li>
          <div class="flex items-center gap-3">
            <span class="inline-flex h-8 w-8 items-center justify-center rounded-full border-2 border-navy-900 bg-surface font-mono text-xs font-bold text-navy-900">
              {i + 1}
            </span>
            <div>
              <p class="text-xs font-semibold uppercase tracking-[0.18em] text-sky-400">
                {wave.timeframe}
              </p>
              <h3 class="text-xl font-semibold text-navy-900">{wave.label}</h3>
            </div>
          </div>
          <div class="mt-5 grid gap-3 sm:grid-cols-2">
            {wave.products.map((product) => (
              <article class="rounded-xl border border-slate-200 bg-surface p-5">
                <div class="flex items-center justify-between gap-3">
                  <h4 class="font-mono text-lg font-bold text-navy-900">{product.name}</h4>
                  <span class={pillClass(product.status)}>{statusLabel[product.status]}</span>
                </div>
                <p class="mt-3 text-sm leading-relaxed text-ink-600">{product.description}</p>
                {product.note && (
                  <p class="mt-3 border-t border-slate-100 pt-2.5 text-xs italic text-ink-400">
                    {product.note}
                  </p>
                )}
              </article>
            ))}
          </div>
          {i < stage2Waves.length - 1 && (
            <div class="flex justify-center pt-8" aria-hidden="true">
              <svg width="20" height="20" viewBox="0 0 20 20" fill="none" stroke="#94A3B8" stroke-width="1.5">
                <path d="M10 4v12M5 11l5 5 5-5" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </div>
          )}
        </li>
      ))}
    </ol>

    <div class="mt-14 rounded-2xl border border-navy-900/10 bg-navy-900 p-8 text-white lg:p-10">
      <p class="text-base leading-relaxed lg:text-xl">
        Shared identity through <span class="font-mono text-sky-400">G8ID</span>. Shared audit through <span class="font-mono text-sky-400">g8audit</span>. Shared workflow through <span class="font-mono text-sky-400">g8flow</span>.
      </p>
      <p class="mt-3 text-base leading-relaxed text-sky-100/90 lg:text-lg">
        One spine. Six new capabilities. No re-platform.
      </p>
    </div>
  </div>
</section>
