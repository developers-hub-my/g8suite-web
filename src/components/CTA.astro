---
const actions = [
  {
    n: '01',
    title: 'Request a Demo',
    body: 'See g8suite in a regulated deployment context — built around your sovereignty and compliance requirements.',
    href: 'mailto:hello@devhub.my?subject=g8suite%20demo%20request',
    cta: 'Book a demo',
  },
  {
    n: '02',
    title: 'Become a Partner',
    body: 'Join the anchored partner network across ASEAN, MENA, and aligned sovereignty markets.',
    href: 'mailto:hello@devhub.my?subject=g8suite%20partner%20enquiry',
    cta: 'Talk partnerships',
  },
  {
    n: '03',
    title: 'Start a Conversation',
    body: 'Not ready for a demo? Tell us what you\'re working on — we\'ll respond within one business day.',
    href: 'mailto:hello@devhub.my',
    cta: 'hello@devhub.my',
  },
];
---

<section id="contact" class="section bg-navy-900 text-white">
  <div class="container-page">
    <header class="max-w-3xl">
      <p class="mb-3 text-xs font-semibold uppercase tracking-[0.18em] text-sky-400">
        Contact
      </p>
      <h2 class="text-3xl font-semibold leading-tight tracking-tight text-white sm:text-4xl lg:text-5xl">
        Ready to consolidate your stack?
      </h2>
      <p class="mt-5 text-lg leading-relaxed text-sky-100">
        Let's talk about what g8suite looks like inside your organisation.
      </p>
    </header>

    <div class="mt-14 grid gap-6 md:grid-cols-3">
      {actions.map((action) => (
        <a
          href={action.href}
          class="group flex h-full flex-col rounded-lg border border-white/10 bg-white/5 p-7 transition-colors hover:border-sky-400 hover:bg-white/10"
        >
          <span class="font-mono text-xs font-medium tracking-wider text-sky-400">{action.n}</span>
          <h3 class="mt-4 text-lg font-semibold text-white">{action.title}</h3>
          <p class="mt-3 flex-1 text-sm leading-relaxed text-sky-100/80">{action.body}</p>
          <span class="mt-6 inline-flex items-center gap-2 text-sm font-medium text-sky-400 transition-colors group-hover:text-white">
            {action.cta}
            <svg width="14" height="14" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
              <path d="M2 7h10M8 3l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
            </svg>
          </span>
        </a>
      ))}
    </div>

    <div class="mt-16 flex flex-col items-start gap-3 border-t border-white/10 pt-10 md:flex-row md:items-center md:justify-between">
      <p class="text-sm text-sky-100/80">
        Developers Hub Sdn Bhd — Johor Bahru, Malaysia
      </p>
      <p class="text-base font-semibold text-white">
        Sovereign. Integrated. Yours.
      </p>
    </div>
  </div>
</section>
