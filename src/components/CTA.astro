---
const actions = [
  {
    n: '01',
    title: 'Request a Demo',
    body: 'See g8suite in a regulated deployment context — built around your sovereignty and compliance requirements.',
    href: 'mailto:hello@devhub.my?subject=g8suite%20demo%20request',
    cta: 'Book a demo',
  },
  {
    n: '02',
    title: 'Become a Partner',
    body: 'Join the anchored partner network across ASEAN, MENA, and aligned sovereignty markets.',
    href: 'mailto:hello@devhub.my?subject=g8suite%20partner%20enquiry',
    cta: 'Talk partnerships',
  },
  {
    n: '03',
    title: 'Start a Conversation',
    body: 'Not ready for a demo? Tell us what you\'re working on — we\'ll respond within one business day.',
    href: 'mailto:hello@devhub.my',
    cta: 'hello@devhub.my',
  },
];
---

<section id="contact" class="relative overflow-hidden bg-navy-900 text-white">
  <div
    class="pointer-events-none absolute inset-0 -z-10"
    aria-hidden="true"
    style="background: radial-gradient(900px 500px at 80% 100%, rgba(123,179,232,0.18), transparent 60%), radial-gradient(700px 400px at 0% 0%, rgba(123,179,232,0.05), transparent 60%);"
  ></div>

  <div class="container-page py-20 lg:py-28">
    <div class="grid gap-12 lg:grid-cols-12 lg:gap-16">
      <header class="lg:col-span-6">
        <p class="mb-4 inline-flex items-center gap-2 rounded-full border border-sky-400/30 bg-sky-400/10 px-3 py-1 text-xs font-semibold uppercase tracking-[0.18em] text-sky-400">
          <span class="h-1.5 w-1.5 rounded-full bg-sky-400"></span>
          Contact
        </p>
        <h2 class="text-3xl font-bold leading-[1.05] tracking-tight text-white sm:text-4xl lg:text-5xl xl:text-6xl">
          Ready to consolidate your stack?
        </h2>
        <p class="mt-6 max-w-xl text-lg leading-relaxed text-sky-100/90">
          Let's talk about what g8suite looks like inside your organisation — your perimeter, your compliance posture, your operating doctrine.
        </p>
        <p class="mt-10 text-2xl font-bold tracking-tight text-white">
          Sovereign. <span class="text-sky-400">Integrated.</span> Yours.
        </p>
      </header>

      <div class="lg:col-span-6">
        <div class="grid gap-3">
          {actions.map((action) => (
            <a
              href={action.href}
              class="group flex items-center justify-between gap-6 rounded-xl border border-white/10 bg-white/5 p-6 transition-colors hover:border-sky-400 hover:bg-white/10"
            >
              <div class="flex items-start gap-5">
                <span class="font-mono text-sm font-semibold text-sky-400">{action.n}</span>
                <div>
                  <h3 class="text-base font-semibold text-white">{action.title}</h3>
                  <p class="mt-1.5 text-sm leading-relaxed text-sky-100/75">{action.body}</p>
                  <span class="mt-3 inline-flex items-center gap-1.5 text-xs font-medium text-sky-400 transition-colors group-hover:text-white">
                    {action.cta}
                  </span>
                </div>
              </div>
              <svg class="h-5 w-5 flex-shrink-0 text-sky-400 transition-transform group-hover:translate-x-1" viewBox="0 0 14 14" fill="none" stroke="currentColor" stroke-width="1.5" aria-hidden="true">
                <path d="M2 7h10M8 3l4 4-4 4" stroke-linecap="round" stroke-linejoin="round" />
              </svg>
            </a>
          ))}
        </div>
      </div>
    </div>

    <div class="mt-16 flex flex-col items-start gap-3 border-t border-white/10 pt-10 md:flex-row md:items-center md:justify-between">
      <p class="text-sm text-sky-100/80">
        Developers Hub Sdn Bhd — Johor Bahru, Malaysia
      </p>
      <p class="font-mono text-xs uppercase tracking-[0.18em] text-sky-100/60">
        Built for regulated organisations across ASEAN &amp; MENA
      </p>
    </div>
  </div>
</section>
